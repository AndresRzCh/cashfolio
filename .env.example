# Application
# SECRET_KEY: 64-character hex string used to sign JWT tokens. Generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-64-char-hex-string
# ACCESS_TOKEN_EXPIRE_MINUTES: Lifetime of the short-lived access token in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS: Lifetime of the long-lived refresh token in days
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
# DATABASE_URL: SQLAlchemy connection string. The path must match the volume mount point (/data)
DATABASE_URL=sqlite:////data/cashfolio.db

# CORS (comma-separated origins)
# CORS_ORIGINS: Allowed origins for browser cross-origin requests. Add your public domain in production
CORS_ORIGINS=http://localhost:5173,http://localhost:80
